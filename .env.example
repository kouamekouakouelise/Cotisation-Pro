# ── Variables d'environnement pour Railway ──────────────────────
# Copier ce fichier, remplir les valeurs, et les ajouter dans
# Railway > Service > Variables

# --- Obligatoire ---
JWT_SECRET=remplacer_par_une_cle_secrete_longue_et_aleatoire
NODE_ENV=production

# --- Email Gmail SMTP (nodemailer) ---
# Utiliser un mot de passe d'application Gmail (pas le mot de passe normal) :
# Google Account > Sécurité > Mots de passe des applications
EMAIL_USER=votre.email@gmail.com
EMAIL_PASS=mot_de_passe_application_16_caracteres

# --- MySQL (injecté automatiquement par le plugin MySQL de Railway) ---
# Ces variables sont ajoutées automatiquement, ne pas les renseigner manuellement :
# MYSQLHOST
# MYSQLPORT
# MYSQLUSER
# MYSQLPASSWORD
# MYSQLDATABASE
# MYSQL_URL

# --- Optionnel ---
# FRONTEND_URL=https://votre-app.railway.app  (inutile si même service)
